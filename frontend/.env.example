# ── Local Development ──────────────────────────────────────
# Backend (Node/Express auth service) — port 5000
REACT_APP_BACKEND_URL=http://localhost:5000

# Degree Recommendation Service (FastAPI) — port 5001
REACT_APP_DEGREE_SERVICE_URL=http://localhost:5001

