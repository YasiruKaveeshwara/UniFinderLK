# ── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/UniFinderLK?retryWrites=true&w=majority

# ── JWT (use a strong random secret in production!) ────────
JWT_SECRET=your-strong-secret-here
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_IN=7

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
